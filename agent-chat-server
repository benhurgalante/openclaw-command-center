// ---------------------------------------------------------------------------
// Operational actions
// ---------------------------------------------------------------------------
function executeAction(action, params) {
  const { execSync } = require("node:child_process");
  const ocBin = path.join(HOME, ".npm-global/bin/openclaw");
  const envPath = `${HOME}/.npm-global/bin:${HOME}/.local/bin:${process.env.PATH || "/usr/bin"}`;
  const execOpts = { timeout: 30000, encoding: "utf-8", env: { ...process.env, HOME, PATH: envPath } };

  const timestamp = new Date().toISOString();
  let result;

  switch (action) {
    case "gateway-restart":
      try {
        execSync(`${ocBin} gateway restart`, execOpts);
        result = { success: true, action, timestamp, message: "Gateway restart initiated" };
      } catch (err) {
        result = { success: false, action, timestamp, error: err.message };
      }
      break;

    case "send-message":
      if (!params.agentId || !params.message) {
        throw new Error("agentId and message required");
      }
      result = sendAgentMessage(params.agentId, params.message);
      result.action = action;
      result.timestamp = timestamp;
      break;

    default:
      throw new Error(`Unknown action: ${action}`);
  }

  // Audit log
  const auditEntry = JSON.stringify({ ...result, params: { ...params, message: params.message ? "[REDACTED]" : undefined } });
  try {
    fs.appendFileSync(path.join(HOME, ".openclaw/logs/command-center-audit.log"), auditEntry + "\n");
  } catch {}

  return result;
}

// ---------------------------------------------------------------------------
// Unified timeline
// ---------------------------------------------------------------------------
function getTimeline() {
  const events = [];

  // Enforcement events
  try {
    const raw = fs.readFileSync(ENFORCEMENT_LOG, "utf-8");
    const lines = raw.trim().split("\n").slice(-50);
    for (const line of lines) {
      try {
        const ev = JSON.parse(line);
        events.push({
          type: "enforcement",
          timestamp: ev.timestamp || ev.ts,
          agent: ev.agentId || ev.agent,
          decision: ev.decision,
          reason: ev.reason_code || ev.reason,
        });
      } catch {}
    }
  } catch {}

  // Retry events
  try {
    const raw = fs.readFileSync(RETRIES_JSON, "utf-8");
    const data = JSON.parse(raw);
    for (const [taskId, task] of Object.entries(data.tasks || {})) {
      events.push({
        type: "retry",
        timestamp: task.updatedAt || task.createdAt,
        taskId,
        status: task.status,
        retryCount: task.retryCount,
        agent: task.agent,
      });
    }
  } catch {}

  // Chat messages (last 20 actual messages from all chats)
  const chats = readChatLogs(null);
  const allMessages = chats.flatMap((c) => (c.messages || []).map((m) => ({ ...m, chatAgent: c.agent || c.from }))).slice(-20);
  for (const msg of allMessages) {
    events.push({
      type: "chat",
      timestamp: msg.timestamp || msg.ts || `${msg.date || ""}T${msg.time || ""}`,
      agent: msg.agent || msg.from || msg.chatAgent,
      to: msg.to,
      preview: (msg.body || msg.content || msg.text || "").slice(0, 80),
    });
  }

  // Sort by timestamp desc
  events.sort((a, b) => {
    const ta = new Date(a.timestamp || 0).getTime();
    const tb = new Date(b.timestamp || 0).getTime();
    return tb - ta;
  });

  return { events: events.slice(0, 100), count: events.length };
}

// ---------------------------------------------------------------------------
// Retention + Archiving (7/30/90 day policy)
// ---------------------------------------------------------------------------
const ARCHIVE_DIR = path.join(HOME, ".openclaw/archive");
const RETENTION_POLICY = { hot: 7, warm: 30, cold: 90 }; // days

function ensureArchiveDir() {
  try { fs.mkdirSync(ARCHIVE_DIR, { recursive: true }); } catch {}
}

function getRetentionStats() {
  ensureArchiveDir();
  const now = Date.now();
  const dayMs = 86400000;

  // Count chat log files by age
  let hotFiles = 0, warmFiles = 0, coldFiles = 0, archivedFiles = 0;
  try {
    const logFiles = fs.readdirSync(LOGS_DIR).filter(f => f.endsWith(".md"));
    for (const f of logFiles) {
      const dateMatch = f.match(/^(\d{4}-\d{2}-\d{2})/);
      if (!dateMatch) { hotFiles++; continue; }
      const ageDays = (now - new Date(dateMatch[1]).getTime()) / dayMs;
      if (ageDays <= RETENTION_POLICY.hot) hotFiles++;
      else if (ageDays <= RETENTION_POLICY.warm) warmFiles++;
      else coldFiles++;
    }
  } catch {}

  try {
    archivedFiles = fs.readdirSync(ARCHIVE_DIR).length;
  } catch {}

  // Enforcement log size
  let enforcementSizeKB = 0;
  try { enforcementSizeKB = Math.round(fs.statSync(ENFORCEMENT_LOG).size / 1024); } catch {}

  return {
    policy: RETENTION_POLICY,
    chatLogs: { hot: hotFiles, warm: warmFiles, cold: coldFiles, archived: archivedFiles },
    enforcementLog: { sizeKB: enforcementSizeKB },
    archiveDir: ARCHIVE_DIR,
  };
}

function runRetentionArchive() {
  ensureArchiveDir();
  const now = Date.now();
  const dayMs = 86400000;
  let archived = 0, errors = 0;

  try {
    const logFiles = fs.readdirSync(LOGS_DIR).filter(f => f.endsWith(".md"));
    for (const f of logFiles) {
      const dateMatch = f.match(/^(\d{4}-\d{2}-\d{2})/);
      if (!dateMatch) continue;
      const ageDays = (now - new Date(dateMatch[1]).getTime()) / dayMs;
      if (ageDays > RETENTION_POLICY.cold) {
        try {
          fs.renameSync(path.join(LOGS_DIR, f), path.join(ARCHIVE_DIR, f));
          archived++;
        } catch { errors++; }
      }
    }
  } catch { errors++; }

  // Trim enforcement log if > 1MB (keep last 500 lines)
  let enforcementTrimmed = false;
  try {
    const stat = fs.statSync(ENFORCEMENT_LOG);
    if (stat.size > 1048576) {
      const lines = fs.readFileSync(ENFORCEMENT_LOG, "utf-8").trim().split("\n");
      fs.writeFileSync(ENFORCEMENT_LOG, lines.slice(-500).join("\n") + "\n");
      enforcementTrimmed = true;
    }
  } catch {}

  return { archived, errors, enforcementTrimmed, timestamp: new Date().toISOString() };
}

// ---------------------------------------------------------------------------
// Kanban Tasks (persistent JSON store)
// ---------------------------------------------------------------------------
const KANBAN_FILE = path.join(HOME, ".openclaw/workspace-maestro/.orchestration/kanban.json");
const KANBAN_COLUMNS = ["backlog", "execucao", "qa_gate", "aprovado", "concluido"];

function loadKanban() {
  try {
    const raw = fs.readFileSync(KANBAN_FILE, "utf-8");
    return JSON.parse(raw);
  } catch {
    return { version: 1, updatedAt: new Date().toISOString(), tasks: {} };
  }
}

function saveKanban(data) {
  data.updatedAt = new Date().toISOString();
  fs.writeFileSync(KANBAN_FILE, JSON.stringify(data, null, 2));
}

function kanbanCreateTask(params) {
  const data = loadKanban();
  const id = params.id || `task-${Date.now()}`;
  if (data.tasks[id]) throw new Error(`Task ${id} already exists`);
  data.tasks[id] = {
    id,
    title: params.title || "Untitled",
    owner: params.owner || null,
    priority: params.priority || "P1",
    column: "backlog",
    attempts: 0,
    maxRetries: 3,
    evidence: [],
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    movedAt: new Date().toISOString(),
    history: [{ action: "created", column: "backlog", at: new Date().toISOString() }],
  };
  saveKanban(data);
  return data.tasks[id];
}

function kanbanMoveTask(taskId, toColumn) {
  if (!KANBAN_COLUMNS.includes(toColumn)) throw new Error(`Invalid column: ${toColumn}`);
  const data = loadKanban();
  const task = data.tasks[taskId];
  if (!task) throw new Error(`Task ${taskId} not found`);

  // Quality gate check: can't move to 'aprovado' without evidence
  if (toColumn === "aprovado" && (!task.evidence || task.evidence.length === 0)) {
    throw new Error("Cannot approve: evidence gate requires at least one evidence entry");
  }

  // Retry limit check
  if (toColumn === "execucao" && task.attempts >= task.maxRetries) {
    throw new Error(`Task ${taskId} exceeded max retries (${task.maxRetries}). Escalate to human.`);
  }

  const fromColumn = task.column;
  task.column = toColumn;
  task.updatedAt = new Date().toISOString();
  task.movedAt = new Date().toISOString();
  if (toColumn === "execucao") task.attempts++;
  task.history.push({ action: "moved", from: fromColumn, to: toColumn, at: new Date().toISOString() });
  saveKanban(data);
  return task;
}

function kanbanAddEvidence(taskId, evidence) {
  const data = loadKanban();
  const task = data.tasks[taskId];
  if (!task) throw new Error(`Task ${taskId} not found`);
  task.evidence.push({ text: evidence, at: new Date().toISOString() });
  task.updatedAt = new Date().toISOString();
  task.history.push({ action: "evidence_added", at: new Date().toISOString() });
  saveKanban(data);
  return task;
}

function kanbanUpdateTask(taskId, updates) {
  const data = loadKanban();
  const task = data.tasks[taskId];
  if (!task) throw new Error(`Task ${taskId} not found`);
  if (updates.title) task.title = updates.title;
  if (updates.owner) task.owner = updates.owner;
  if (updates.priority) task.priority = updates.priority;
  task.updatedAt = new Date().toISOString();
  saveKanban(data);
  return task;
}

function kanbanGetBoard() {
  const data = loadKanban();
  const board = {};
  for (const col of KANBAN_COLUMNS) board[col] = [];
  for (const task of Object.values(data.tasks)) {
    const col = task.column || "backlog";
    if (board[col]) board[col].push(task);
  }
  // Sort by priority then age
  for (const col of KANBAN_COLUMNS) {
    board[col].sort((a, b) => {
      const pa = a.priority || "P2";
      const pb = b.priority || "P2";
      if (pa !== pb) return pa.localeCompare(pb);
      return new Date(a.createdAt) - new Date(b.createdAt);
    });
  }
  return { columns: KANBAN_COLUMNS, board, taskCount: Object.keys(data.tasks).length, updatedAt: data.updatedAt };
}

