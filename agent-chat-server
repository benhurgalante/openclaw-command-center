        if (netOut) {
          const parts = netOut.split(/\s+/);
          net = { iface: parts[0].replace(":", ""), rxBytes: parseInt(parts[1]) || 0, txBytes: parseInt(parts[9]) || 0 };
        }
      } catch {}

      // Key processes
      const procs = [];
      const procNames = [
        { name: "gateway", match: "openclaw.*gateway" },
        { name: "agent-chat-server", match: "agent-chat-server" },
        { name: "ollama", match: "ollama" },
      ];
      for (const p of procNames) {
        try {
          const out = execSync(`ps aux | grep -E '${p.match}' | grep -v grep | head -1`, { encoding: "utf-8", timeout: 3000 }).trim();
          if (out) {
            const cols = out.split(/\s+/);
            procs.push({ name: p.name, pid: parseInt(cols[1]) || 0, cpu: parseFloat(cols[2]) || 0, mem: parseFloat(cols[3]) || 0, rss: parseInt(cols[5]) || 0, status: "running" });
          } else {
            procs.push({ name: p.name, pid: 0, cpu: 0, mem: 0, rss: 0, status: "stopped" });
          }
        } catch {
          procs.push({ name: p.name, pid: 0, cpu: 0, mem: 0, rss: 0, status: "unknown" });
        }
      }

      // CPU usage (aggregate from /proc/stat snapshot)
      let cpuPct = 0;
      try {
        const statOut = execSync("head -1 /proc/stat", { encoding: "utf-8", timeout: 2000 }).trim();
        const vals = statOut.split(/\s+/).slice(1).map(Number);
        const idle = vals[3] + (vals[4] || 0);
        const total = vals.reduce((s, v) => s + v, 0);
        // Store for delta calc; for now use load-based estimate
