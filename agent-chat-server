// ---------------------------------------------------------------------------
// Chat log parser — converts markdown logs to structured JSON
// ---------------------------------------------------------------------------
function parseChatLog(content, filename) {
  const messages = [];
  const basename = path.basename(filename, ".md");

  // Header: "# Chat: terminal ↔ maestro"
  const headerMatch = content.match(
    /^#\s+Chat:\s+(\S+)\s+.*?\s+(\S+)\s*$/m
  );
  const agents = headerMatch
    ? [headerMatch[1], headerMatch[2]]
    : basename.replace(/^\d{4}-\d{2}-\d{2}-/, "").split("-");

  // Date from header or filename
  const dateMatch =
    content.match(/\*\*Data:\*\*\s*(\S+)/) ||
    basename.match(/^(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : new Date().toISOString().slice(0, 10);

  // Parse messages: ### [HH:MM:SS] agent
  const msgRegex = /^###\s+\[(\d{2}:\d{2}:\d{2})\]\s+(\S+)\s*$/gm;
  let match;
  const positions = [];

  while ((match = msgRegex.exec(content)) !== null) {
    positions.push({
      time: match[1],
      agent: match[2],
      startIndex: match.index + match[0].length,
    });
  }

  for (let i = 0; i < positions.length; i++) {
    const pos = positions[i];
    const endIndex =
      i + 1 < positions.length ? positions[i + 1].startIndex : content.length;

    // Grab text between this header and the next (or EOF), trim whitespace
    const bodyStart = pos.startIndex;
    const rawBody = content.slice(bodyStart, endIndex);
    // Remove trailing ### line that belongs to next message
    const body = rawBody.replace(/\n###\s+\[.*$/, "").trim();

    messages.push({
      id: `${basename}-${i}`,
      timestamp: `${date}T${pos.time}`,
      agent: pos.agent,
      body,
      chat: basename,
    });
  }

  return { chat: basename, date, agents, messages };
}

// ---------------------------------------------------------------------------
// File readers
// ---------------------------------------------------------------------------
function readChatLogs(agentFilter) {
  const results = [];
  let files;
  try {
    files = fs.readdirSync(LOGS_DIR).filter((f) => f.endsWith(".md"));
  } catch {
    return results;
  }

  const today = new Date().toISOString().slice(0, 10);

  for (const file of files) {
    // Only today's logs by default
    if (!file.startsWith(today)) continue;

    const filepath = path.join(LOGS_DIR, file);
    try {
      const content = fs.readFileSync(filepath, "utf-8");
      const parsed = parseChatLog(content, file);

      if (agentFilter) {
        const lower = agentFilter.toLowerCase();
        if (
          !parsed.agents.some((a) => a.toLowerCase() === lower) &&
          !parsed.messages.some((m) => m.agent.toLowerCase() === lower)
        ) {
          continue;
        }
      }

      results.push(parsed);
    } catch {
      // skip unreadable files
    }
  }

  return results;
}

function readEnforcementLog() {
  try {
    const raw = fs.readFileSync(ENFORCEMENT_LOG, "utf-8").trim();
    if (!raw) return [];
    return raw.split("\n").map((line) => {
      try {
        return JSON.parse(line);
      } catch {
        return { raw: line };
      }
    });
  } catch {
    return [];
  }
}

function readRetries() {
  try {
    return JSON.parse(fs.readFileSync(RETRIES_JSON, "utf-8"));
  } catch {
    return { version: 1, updatedAt: null, tasks: {} };
  }
}

// Read request body as JSON
function readBody(req) {
  return new Promise((resolve, reject) => {
    let data = "";
    req.on("data", (chunk) => {
      data += chunk;
      if (data.length > 256 * 1024) {
        reject(new Error("Payload too large"));
        req.destroy();
      }
    });
    req.on("end", () => {
      try {
        resolve(JSON.parse(data));
      } catch {
        reject(new Error("Invalid JSON"));
      }
    });
    req.on("error", reject);
  });
}

// Send message to agent via openclaw CLI
function sendAgentMessage(agentId, message) {
  const { execSync } = require("node:child_process");
  try {
    const ocBin = path.join(HOME, ".npm-global/bin/openclaw");
    const escaped = message.replace(/'/g, "'\\''");
    const result = execSync(
      `${ocBin} agent --agent ${agentId} --message '${escaped}' --json`,
      { timeout: 120000, encoding: "utf-8", env: { ...process.env, HOME, PATH: `${HOME}/.npm-global/bin:${HOME}/.local/bin:${process.env.PATH || "/usr/bin"}` } }
    );
    return { success: true, response: result.trim() };
  } catch (err) {
    return { success: false, error: err.message };
  }
}

// Fetch OpenClaw system status
function getSystemStatus() {
  const { execSync } = require("node:child_process");
  try {
    const ocBin = path.join(HOME, ".npm-global/bin/openclaw");
    const raw = execSync(`${ocBin} status --json`, {
      timeout: 15000,
      encoding: "utf-8",
      env: { ...process.env, HOME, PATH: `${HOME}/.npm-global/bin:${HOME}/.local/bin:${process.env.PATH || "/usr/bin"}` },
    });
    const data = JSON.parse(raw);
    return {
      gateway: {
        mode: data.gateway?.mode || "unknown",
        reachable: data.gateway?.reachable || false,
        latencyMs: data.gateway?.connectLatencyMs || null,
        version: data.gateway?.self?.version || "unknown",
        host: data.gateway?.self?.host || "unknown",
        platform: data.gateway?.self?.platform || "unknown",
      },
      update: {
        current: data.gateway?.self?.version || "unknown",
        latest: data.update?.registry?.latestVersion || "unknown",
        updateAvailable:
          data.gateway?.self?.version !== data.update?.registry?.latestVersion,
      },
      agents: {
        total: (data.heartbeat?.agents || []).length,
        heartbeatEnabled: (data.heartbeat?.agents || []).filter(
          (a) => a.enabled
        ).length,
        defaultAgent: data.heartbeat?.defaultAgentId || "maestro",
      },
      channels: data.channels || {},
      sessions: {
        count: (data.sessions?.paths || []).length,
      },
    };
  } catch (err) {
    return { error: err.message };
  }
}

