// WebSocket upgrade
server.on("upgrade", (req, socket, head) => {
  const key = req.headers["sec-websocket-key"];
  if (!key) {
    socket.destroy();
    return;
  }

  const acceptKey = computeAcceptKey(key);
  const headers = [
    "HTTP/1.1 101 Switching Protocols",
    "Upgrade: websocket",
    "Connection: Upgrade",
    `Sec-WebSocket-Accept: ${acceptKey}`,
    "",
    "",
  ].join("\r\n");

  socket.write(headers);
  wsClients.add(socket);
  wsClientMeta.set(socket, { lastPong: Date.now(), missedPings: 0 });
  sloMetrics.wsConnections++;

  log(`WS client connected (total: ${wsClients.size})`);

  // Send initial state
  const initial = {
    type: "init",
    chats: readChatLogs(null),
    enforcement: readEnforcementLog().slice(-20),
    retries: readRetries(),
  };
  try {
    socket.write(encodeFrame(JSON.stringify(initial)));
  } catch {
    // ignore
  }

  // Handle incoming frames
  let buffer = Buffer.alloc(0);
  socket.on("data", (chunk) => {
    buffer = Buffer.concat([buffer, chunk]);
    while (buffer.length > 0) {
      const frame = decodeFrame(buffer);
      if (!frame) break;
      buffer = buffer.slice(frame.totalLength);

      // Close frame
      if (frame.opcode === 0x08) {
        const closeFrame = Buffer.alloc(2);
        closeFrame[0] = 0x88;
        closeFrame[1] = 0;
        try {
          socket.write(closeFrame);
        } catch {
          // ignore
        }
        socket.end();
        return;
      }

      // Pong (response to our ping) — track last pong time
      if (frame.opcode === 0x0a) {
        const meta = wsClientMeta.get(socket) || { lastPong: Date.now(), missedPings: 0 };
        meta.lastPong = Date.now();
        meta.missedPings = 0;
        wsClientMeta.set(socket, meta);
        continue;
      }

      // Ping from client — send pong
      if (frame.opcode === 0x09) {
        const pong = Buffer.alloc(2 + frame.payload.length);
        pong[0] = 0x8a; // FIN + pong
        pong[1] = frame.payload.length;
        frame.payload.copy(pong, 2);
        try {
          socket.write(pong);
        } catch {
          // ignore
        }
        continue;
      }
    }
  });

  socket.on("close", () => {
    wsClients.delete(socket);
    sloMetrics.wsDisconnections++;
    log(`WS client disconnected (total: ${wsClients.size})`);
  });

  socket.on("error", () => {
    wsClients.delete(socket);
  });
});

// ---------------------------------------------------------------------------
// File watchers — broadcast changes in real-time
// ---------------------------------------------------------------------------
const watchedFiles = new Map(); // filename -> last mtime

function startWatchers() {
  // Ensure logs dir exists
  try {
    fs.mkdirSync(LOGS_DIR, { recursive: true });
  } catch {
    // ignore
  }

  // Watch chat logs directory
  try {
    fs.watch(LOGS_DIR, { persistent: true }, (eventType, filename) => {
      if (!filename || !filename.endsWith(".md")) return;

      const filepath = path.join(LOGS_DIR, filename);
      try {
        const stat = fs.statSync(filepath);
        const lastMtime = watchedFiles.get(filename);

        if (lastMtime && stat.mtimeMs <= lastMtime) return;
        watchedFiles.set(filename, stat.mtimeMs);

        const content = fs.readFileSync(filepath, "utf-8");
        const parsed = parseChatLog(content, filename);

        broadcast({
          type: "chat_update",
          chat: parsed.chat,
          agents: parsed.agents,
          date: parsed.date,
          messages: parsed.messages,
          updatedAt: new Date().toISOString(),
        });

        log(`Chat updated: ${filename} (${parsed.messages.length} msgs)`);
      } catch {
        // file may have been deleted
      }
    });
    log(`Watching chat logs: ${LOGS_DIR}`);
  } catch (err) {
    log(`Warning: could not watch ${LOGS_DIR}: ${err.message}`);
  }

  // Watch enforcement log
  try {
    const enforcementDir = path.dirname(ENFORCEMENT_LOG);
    fs.mkdirSync(enforcementDir, { recursive: true });

    let lastEnforcementSize = 0;
    try {
      lastEnforcementSize = fs.statSync(ENFORCEMENT_LOG).size;
    } catch {
      // file may not exist yet
    }

    fs.watch(enforcementDir, { persistent: true }, (eventType, filename) => {
      if (filename !== path.basename(ENFORCEMENT_LOG)) return;

      try {
        const stat = fs.statSync(ENFORCEMENT_LOG);
        if (stat.size <= lastEnforcementSize) {
          lastEnforcementSize = stat.size;
          return;
        }

        // Read only the new bytes
        const fd = fs.openSync(ENFORCEMENT_LOG, "r");
        const newBytes = Buffer.alloc(stat.size - lastEnforcementSize);
        fs.readSync(fd, newBytes, 0, newBytes.length, lastEnforcementSize);
        fs.closeSync(fd);
        lastEnforcementSize = stat.size;

        const newLines = newBytes.toString("utf-8").trim().split("\n");
        for (const line of newLines) {
          try {
            const entry = JSON.parse(line);
            broadcast({ type: "enforcement", ...entry });
          } catch {
            // skip malformed lines
          }
        }

        log(`Enforcement log: ${newLines.length} new entries`);
      } catch {
        // ignore
      }
    });
    log(`Watching enforcement log: ${ENFORCEMENT_LOG}`);
  } catch (err) {
    log(`Warning: could not watch enforcement log: ${err.message}`);
  }

  // Watch retries.json
  try {
    const retriesDir = path.dirname(RETRIES_JSON);
    fs.watch(retriesDir, { persistent: true }, (eventType, filename) => {
      if (filename !== path.basename(RETRIES_JSON)) return;

      try {
        const data = readRetries();
        broadcast({ type: "retries_update", ...data });
        log("Retries state updated");
      } catch {
        // ignore
      }
    });
    log(`Watching retries: ${RETRIES_JSON}`);
  } catch (err) {
    log(`Warning: could not watch retries: ${err.message}`);
  }
}

// ---------------------------------------------------------------------------
// Heartbeat — keep WS connections alive (P1: per-client timeout tracking)
// ---------------------------------------------------------------------------
const WS_PING_INTERVAL = 30000;
const WS_PONG_TIMEOUT = 10000;
const wsClientMeta = new WeakMap(); // socket -> { lastPong, missedPings }

setInterval(() => {
  const now = Date.now();
  for (const client of wsClients) {
    const meta = wsClientMeta.get(client) || { lastPong: now, missedPings: 0 };
    // If no pong received since last ping, increment missed count
    if (now - meta.lastPong > WS_PING_INTERVAL + WS_PONG_TIMEOUT) {
      meta.missedPings++;
      if (meta.missedPings >= 3) {
        log(`WS zombie client detected (${meta.missedPings} missed pings), closing`);
        try { client.end(); } catch {}
        wsClients.delete(client);
        continue;
      }
    }
    wsClientMeta.set(client, meta);
    sendPing(client);
  }
}, WS_PING_INTERVAL);

// ---------------------------------------------------------------------------
// Observability persistence — flush snapshot every 5 minutes
// ---------------------------------------------------------------------------
setInterval(() => {
  try {
    const snapshot = {
      ts: new Date().toISOString(),
      slo: {
        requestCount: sloMetrics.requestCount,
        errorCount: sloMetrics.errorCount,
        wsConnections: sloMetrics.wsConnections,
        wsDisconnections: sloMetrics.wsDisconnections,
        uptimeS: Math.round((Date.now() - sloMetrics.startedAt) / 1000),
      },
      obs: getObservability(),
    };
    // Append to ring buffer file (keep last 288 entries = 24h at 5min intervals)
    let history = [];
    try { history = JSON.parse(fs.readFileSync(OBS_SNAPSHOT_FILE, "utf-8")); } catch {}
    if (!Array.isArray(history)) history = [];
    history.push(snapshot);
    if (history.length > 288) history = history.slice(-288);
    fs.writeFileSync(OBS_SNAPSHOT_FILE, JSON.stringify(history, null, 2));
  } catch (err) {
    // Silently ignore persistence errors — obs is best-effort
  }
}, 300000); // 5 minutes

// ---------------------------------------------------------------------------
// Logging
// ---------------------------------------------------------------------------
function log(msg) {
  const ts = new Date().toISOString();
  process.stdout.write(`[${ts}] ${msg}\n`);
}

// ---------------------------------------------------------------------------
// Start
// ---------------------------------------------------------------------------
server.listen(PORT, "127.0.0.1", () => {
  log(`Agent Chat Bridge running on http://127.0.0.1:${PORT}`);
  log(`WebSocket endpoint: ws://127.0.0.1:${PORT}`);
  log(`REST: /api/chats, /api/chats/:agent, /api/enforcement, /api/retries`);
  log(`Test page: http://127.0.0.1:${PORT}/`);
  startWatchers();
});

// Graceful shutdown
process.on("SIGTERM", () => {
  log("SIGTERM received, shutting down...");
  for (const client of wsClients) {
    try {
      const closeFrame = Buffer.alloc(2);
      closeFrame[0] = 0x88;
      closeFrame[1] = 0;
      client.write(closeFrame);
      client.end();
    } catch {
      // ignore
    }
  }
  server.close(() => process.exit(0));
  setTimeout(() => process.exit(0), 5000);
});

process.on("SIGINT", () => {
  log("SIGINT received, shutting down...");
  server.close(() => process.exit(0));
  setTimeout(() => process.exit(0), 2000);
});
