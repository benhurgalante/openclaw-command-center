    try {
      const cpus = os.cpus();
      const cpuCount = cpus.length;
      const loadAvg = os.loadavg();
      const totalMem = os.totalmem();
      const freeMem = os.freemem();
      const usedMem = totalMem - freeMem;
      const memPct = (usedMem / totalMem * 100).toFixed(1);

      // Disk usage
      let disk = { total: 0, used: 0, free: 0, pct: 0, mount: "/" };
      try {
        const dfOut = execSync("df -B1 / | tail -1", { encoding: "utf-8", timeout: 5000 }).trim().split(/\s+/);
        disk = { total: parseInt(dfOut[1]) || 0, used: parseInt(dfOut[2]) || 0, free: parseInt(dfOut[3]) || 0, pct: parseFloat(dfOut[4]) || 0, mount: dfOut[5] || "/" };
      } catch {}

      // Network (basic: bytes rx/tx from /proc/net/dev)
