function getAgentsList() {
  const { execSync } = require("node:child_process");
  const fs = require("node:fs");
  try {
    const ocBin = path.join(HOME, ".npm-global/bin/openclaw");
    const envPath = `${HOME}/.npm-global/bin:${HOME}/.local/bin:${process.env.PATH || "/usr/bin"}`;
    const raw = execSync(`${ocBin} agents list --json`, {
      timeout: 15000, encoding: "utf-8",
      env: { ...process.env, HOME, PATH: envPath },
    });
    const agents = JSON.parse(raw);

    // Enrich each agent with IDENTITY.md data + operational metrics
    const chats = readChatLogs();
    const msgCounts = {};
    for (const chat of chats) {
      for (const msg of (chat.messages || [])) {
        const ag = (msg.agent || "").toLowerCase();
        msgCounts[ag] = (msgCounts[ag] || 0) + 1;
      }
    }

    // Sector mapping (from organogram)
    const sectorMap = {
      maestro: "CEO", sysdev: "CTO", coder: "CTO", clawdev: "CTO", designer: "CTO",
      cio: "CIO", terminal: "CIO",
      flow: "COO", ops: "COO", briefer: "COO", concierge: "COO", travel: "COO",
      finance: "CFO", analyst: "CFO", deals: "CFO",
      ads: "CMO", sales: "CMO", copywriter: "CMO", creator: "CMO", "social-media": "CMO", "video-studio": "CMO",
      hr: "CHRO", advisor: "CHRO", stylist: "CHRO",
      juris: "CLO",
      sentinel: "CCO", scout: "CCO",
    };

    const enriched = (Array.isArray(agents) ? agents : []).map(a => {
      const id = (a.id || "").toLowerCase();
      // Read IDENTITY.md
      let role = "";
      let cargo = "";
      try {
        const ws = a.workspace || "";
        const idFile = path.join(ws, "IDENTITY.md");
        if (fs.existsSync(idFile)) {
          const content = fs.readFileSync(idFile, "utf-8").slice(0, 1000);
          const cargoMatch = content.match(/Cargo:\s*(.+)/i);
          if (cargoMatch) cargo = cargoMatch[1].trim();
          const roleMatch = content.match(/Role:\s*(.+)/i);
          if (roleMatch) role = roleMatch[1].trim().slice(0, 120);
        }
      } catch {}

      return {
        ...a,
        sector: sectorMap[id] || "—",
        cargo: cargo || "—",
        role: role || "—",
        messages: msgCounts[id] || 0,
        status: "ready",
      };
    });

    return enriched;
  } catch {
    return [];
  }
}

