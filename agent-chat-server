// ---------------------------------------------------------------------------
// HTTP server + WebSocket upgrade
// ---------------------------------------------------------------------------
const server = http.createServer((req, res) => {
  res._req = req;
  const reqStart = Date.now();
  const url = new URL(req.url, `http://localhost:${PORT}`);
  const pathname = url.pathname;
  const clientIp = req.socket.remoteAddress || "unknown";

  sloMetrics.requestCount++;

  // Rate limiting
  const rl = checkRateLimit(clientIp);
  if (!rl.allowed) {
    sloMetrics.errorCount++;
    setCors(res);
    res.writeHead(429, {
      "Content-Type": "application/json",
      "Retry-After": String(rl.retryAfter),
    });
    res.end(JSON.stringify({ error: "Too many requests", retryAfter: rl.retryAfter }));
    return;
  }

  // Track response for SLO + observability
  const origEnd = res.end.bind(res);
  res.end = function (...args) {
    const dur = Date.now() - reqStart;
    recordLatency(dur);
    recordEndpointMetric(pathname, dur, res.statusCode);
    if (res.statusCode >= 400) sloMetrics.errorCount++;
    return origEnd(...args);
  };

  // CORS preflight
  if (req.method === "OPTIONS") {
    setCors(res);
    res.writeHead(204);
    res.end();
    return;
  }

  // RBAC middleware for critical endpoints
  const authz = authorizeRequest(req, pathname);
  if (isCriticalEndpoint(pathname)) {
    const endpointLabel = `${req.method} ${pathname}`;
    auditRbac({ role: authz.role, actor: authz.actor, decision: authz.allowed ? "allow" : "deny", endpoint: endpointLabel });
    if (!authz.allowed) {
      jsonResponse(res, { error: "forbidden", reason: authz.reason, required: "x-role: admin|operator|viewer" }, 403);
      return;
    }
  }

  // Static file serving for widget assets
  const STATIC_DIR = path.join(HOME, ".openclaw/agent-chats");
  const MIME_TYPES = {
    ".html": "text/html",
    ".js": "application/javascript",
    ".css": "text/css",
    ".json": "application/json",
    ".svg": "image/svg+xml",
