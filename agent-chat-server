function loadJsonStore(filePath, fallback) {
  try {
    return JSON.parse(fs.readFileSync(filePath, "utf-8"));
  } catch {
    return fallback;
  }
}

function saveJsonStore(filePath, data) {
  fs.writeFileSync(filePath, JSON.stringify(data, null, 2));
}

function evolutionList() {
  return loadJsonStore(EVOLUTION_FILE, { version: 1, updatedAt: null, events: [] });
}

function evolutionCreate(params) {
