// Compute metrics from chat logs
function computeMetrics() {
  const chats = readChatLogs(null);
  const agentMsgCount = {};
  let totalMessages = 0;
  const agentSet = new Set();

  for (const chat of chats) {
    for (const msg of chat.messages) {
      agentMsgCount[msg.agent] = (agentMsgCount[msg.agent] || 0) + 1;
      agentSet.add(msg.agent);
      totalMessages++;
    }
    for (const a of chat.agents) agentSet.add(a);
  }

  const enforcement = readEnforcementLog();
  const retries = readRetries();
  const activeRetries = Object.values(retries.tasks || {}).filter(
    (t) => t.status === "active" || t.status === "retrying"
  ).length;
  const escalations = Object.values(retries.tasks || {}).filter(
    (t) => t.status === "escalated"
  ).length;

  return {
    activeAgents: agentSet.size,
    totalMessages,
    messagesByAgent: agentMsgCount,
    totalChats: chats.length,
    enforcementEvents: enforcement.length,
    activeRetries,
    escalations,
    wsClients: wsClients.size,
    uptime: process.uptime(),
  };
}

// ---------------------------------------------------------------------------
// WebSocket helpers (RFC 6455 minimal implementation)
// ---------------------------------------------------------------------------
function computeAcceptKey(key) {
  return crypto
    .createHash("sha1")
    .update(key + "258EAFA5-E914-47DA-95CA-5AB5AE11E54E")
    .digest("base64");
}

function encodeFrame(data) {
  const payload =
    typeof data === "string" ? Buffer.from(data, "utf-8") : data;
  const len = payload.length;
  let header;

  if (len < 126) {
    header = Buffer.alloc(2);
    header[0] = 0x81; // FIN + text opcode
    header[1] = len;
  } else if (len < 65536) {
    header = Buffer.alloc(4);
    header[0] = 0x81;
    header[1] = 126;
    header.writeUInt16BE(len, 2);
  } else {
    header = Buffer.alloc(10);
    header[0] = 0x81;
    header[1] = 127;
    header.writeBigUInt64BE(BigInt(len), 2);
  }

  return Buffer.concat([header, payload]);
}

function decodeFrame(buf) {
  if (buf.length < 2) return null;
  const opcode = buf[0] & 0x0f;
  const masked = (buf[1] & 0x80) !== 0;
  let payloadLen = buf[1] & 0x7f;
  let offset = 2;

  if (payloadLen === 126) {
    if (buf.length < 4) return null;
    payloadLen = buf.readUInt16BE(2);
    offset = 4;
  } else if (payloadLen === 127) {
    if (buf.length < 10) return null;
    payloadLen = Number(buf.readBigUInt64BE(2));
    offset = 10;
  }

  let mask = null;
  if (masked) {
    if (buf.length < offset + 4) return null;
    mask = buf.slice(offset, offset + 4);
    offset += 4;
  }

  if (buf.length < offset + payloadLen) return null;
  const payload = buf.slice(offset, offset + payloadLen);

  if (mask) {
    for (let i = 0; i < payload.length; i++) {
      payload[i] ^= mask[i % 4];
    }
  }

  return { opcode, payload, totalLength: offset + payloadLen };
}

// ---------------------------------------------------------------------------
// WebSocket client tracking
// ---------------------------------------------------------------------------
const wsClients = new Set();

function broadcast(data) {
  const json = typeof data === "string" ? data : JSON.stringify(data);
  const frame = encodeFrame(json);
  for (const client of wsClients) {
    try {
      client.write(frame);
    } catch {
      wsClients.delete(client);
    }
  }
}

function sendPing(socket) {
  try {
    const pingFrame = Buffer.alloc(2);
    pingFrame[0] = 0x89; // FIN + ping
    pingFrame[1] = 0;
    socket.write(pingFrame);
  } catch {
    // ignore
  }
}

// ---------------------------------------------------------------------------
// Rate Limiting (per-IP, sliding window)
// ---------------------------------------------------------------------------
const rateLimitMap = new Map(); // ip -> { count, resetAt }
const RATE_LIMIT_WINDOW = 60000; // 1 minute
const RATE_LIMIT_MAX = 120; // requests per window
const RATE_LIMIT_WS_MAX = 60; // WS messages per window per client

function checkRateLimit(ip) {
  const now = Date.now();
  let entry = rateLimitMap.get(ip);
  if (!entry || now > entry.resetAt) {
    entry = { count: 0, resetAt: now + RATE_LIMIT_WINDOW };
    rateLimitMap.set(ip, entry);
  }
  entry.count++;
  if (entry.count > RATE_LIMIT_MAX) {
    return { allowed: false, remaining: 0, retryAfter: Math.ceil((entry.resetAt - now) / 1000) };
  }
  return { allowed: true, remaining: RATE_LIMIT_MAX - entry.count };
}

// Cleanup stale entries every 5 minutes
setInterval(() => {
  const now = Date.now();
  for (const [ip, entry] of rateLimitMap) {
    if (now > entry.resetAt) rateLimitMap.delete(ip);
  }
}, 300000);

// ---------------------------------------------------------------------------
// SLO Tracking
// ---------------------------------------------------------------------------
const sloMetrics = {
  requestCount: 0,
  errorCount: 0, // 4xx + 5xx
  latencies: [], // last 100 request durations in ms
  wsConnections: 0,
  wsDisconnections: 0,
  startedAt: Date.now(),
};

// ---------------------------------------------------------------------------
// Observability — per-endpoint metrics + frontend error tracking
// ---------------------------------------------------------------------------
const obsMetrics = {
  endpoints: {},        // { "/api/status": { count, totalMs, errors, p95s: [] } }
  frontendErrors: [],   // last 50 JS errors reported by dashboard
  renderTimes: [],      // last 100 render cycle times reported by dashboard
  wsReconnects: 0,
};

function recordEndpointMetric(pathname, durationMs, statusCode) {
  if (!obsMetrics.endpoints[pathname]) {
    obsMetrics.endpoints[pathname] = { count: 0, totalMs: 0, errors: 0, latencies: [] };
  }
  const ep = obsMetrics.endpoints[pathname];
  ep.count++;
  ep.totalMs += durationMs;
  if (statusCode >= 400) ep.errors++;
  ep.latencies.push(durationMs);
  if (ep.latencies.length > 50) ep.latencies.shift();
}

function getObservability() {
  const epSummary = {};
  for (const [ep, m] of Object.entries(obsMetrics.endpoints)) {
    const sorted = m.latencies.slice().sort((a, b) => a - b);
    const p50 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.5)] : 0;
    const p95 = sorted.length > 0 ? sorted[Math.floor(sorted.length * 0.95)] : 0;
    epSummary[ep] = {
      count: m.count,
      avgMs: m.count > 0 ? Math.round(m.totalMs / m.count) : 0,
      p50, p95,
      errors: m.errors,
      errorRate: m.count > 0 ? (m.errors / m.count * 100).toFixed(1) + "%" : "0%",
    };
  }
  const renderSorted = obsMetrics.renderTimes.slice().sort((a, b) => a - b);
  return {
    server: {
      uptime: process.uptime(),
      memoryMB: Math.round(process.memoryUsage().rss / 1048576),
      heapMB: Math.round(process.memoryUsage().heapUsed / 1048576),
      wsClients: wsClients ? wsClients.size : 0,
      wsReconnects: obsMetrics.wsReconnects,
    },
    endpoints: epSummary,
    frontend: {
      jsErrors: obsMetrics.frontendErrors.slice(-20),
      renderTimes: {
        samples: renderSorted.length,
        p50: renderSorted.length > 0 ? renderSorted[Math.floor(renderSorted.length * 0.5)] : 0,
        p95: renderSorted.length > 0 ? renderSorted[Math.floor(renderSorted.length * 0.95)] : 0,
        last: renderSorted.length > 0 ? renderSorted[renderSorted.length - 1] : 0,
      },
    },
    alerts: {
      highServerMemory: process.memoryUsage().rss > 256 * 1048576,
      slowRender: (renderSorted.length > 0 && renderSorted[Math.floor(renderSorted.length * 0.95)] > 2000),
      highEndpointErrors: Object.values(epSummary).some(e => parseFloat(e.errorRate) > 10),
    },
  };
}

function recordLatency(ms) {
  sloMetrics.latencies.push(ms);
  if (sloMetrics.latencies.length > 100) sloMetrics.latencies.shift();
}

function computeSLOs() {
  const lat = sloMetrics.latencies.slice().sort((a, b) => a - b);
  const p50 = lat.length > 0 ? lat[Math.floor(lat.length * 0.5)] : 0;
  const p95 = lat.length > 0 ? lat[Math.floor(lat.length * 0.95)] : 0;
  const p99 = lat.length > 0 ? lat[Math.floor(lat.length * 0.99)] : 0;
  const uptimeMs = Date.now() - sloMetrics.startedAt;
  const errorRate = sloMetrics.requestCount > 0
    ? (sloMetrics.errorCount / sloMetrics.requestCount * 100).toFixed(2)
    : "0.00";

  return {
    uptime: {
      ms: uptimeMs,
      human: `${Math.floor(uptimeMs / 3600000)}h ${Math.floor((uptimeMs % 3600000) / 60000)}m`,
    },
    requests: {
      total: sloMetrics.requestCount,
      errors: sloMetrics.errorCount,
      errorRate: `${errorRate}%`,
    },
    latency: {
      p50: `${p50}ms`,
      p95: `${p95}ms`,
      p99: `${p99}ms`,
      samples: lat.length,
    },
    websocket: {
      activeClients: wsClients.size,
      totalConnections: sloMetrics.wsConnections,
      totalDisconnections: sloMetrics.wsDisconnections,
    },
    alerts: {
      highErrorRate: parseFloat(errorRate) > 5,
      highLatency: p95 > 5000,
      noClients: wsClients.size === 0,
    },
    thresholds: {
      errorRate: "< 5%",
      p95Latency: "< 5000ms",
      minWsClients: 0,
    },
  };
}

// ---------------------------------------------------------------------------
// RBAC + Audit (server-side enforcement)
// ---------------------------------------------------------------------------
const RBAC_ROLES = new Set(["admin", "operator", "viewer"]);
const ADMIN_ONLY_ACTIONS = new Set([
  "gateway-restart",
  "go",
  "no-go",
  "gono-go",
  "go-no-go",
  "approve-release",
  "rollback-release",
]);

function normalizeRole(value) {
  const role = String(value || "").trim().toLowerCase();
  return RBAC_ROLES.has(role) ? role : null;
}

function getActor(req) {
  return (
    req.headers["x-actor"] ||
    req.headers["x-user"] ||
    req.headers["x-agent-id"] ||
    "anonymous"
  );
}

function isReadMethod(method) {
  return method === "GET" || method === "HEAD";
}

function isCriticalEndpoint(pathname) {
  return (
    pathname.startsWith("/api/actions") ||
    pathname.startsWith("/api/kanban") ||
    pathname.startsWith("/api/evolution") ||
    pathname.startsWith("/api/incidents") ||
    pathname === "/api/messages"
  );
}

function auditRbac({ role, actor, decision, endpoint }) {
  const entry = {
    ts: new Date().toISOString(),
    role: role || "unknown",
    actor: actor || "anonymous",
    decision,
    endpoint,
  };
  try {
    fs.appendFileSync(RBAC_AUDIT_LOG, JSON.stringify(entry) + "\n");
  } catch {}
}

function authorizeRequest(req, pathname) {
  if (!isCriticalEndpoint(pathname)) {
    return { allowed: true, role: null, actor: getActor(req), reason: "non-critical" };
  }

  const role = normalizeRole(req.headers["x-role"] || req.headers["x-user-role"]);
  const actor = getActor(req);
  if (!role) {
    return { allowed: false, role: "unknown", actor, reason: "missing_or_invalid_role_header" };
  }

  if (pathname.startsWith("/api/actions/")) {
    const action = pathname.slice("/api/actions/".length).toLowerCase();
    if (role === "viewer") return { allowed: false, role, actor, reason: "viewer_read_only" };
    if (role === "operator" && ADMIN_ONLY_ACTIONS.has(action)) {
      return { allowed: false, role, actor, reason: "operator_cannot_execute_admin_action" };
    }
    return { allowed: true, role, actor, reason: "ok" };
  }

  if (!isReadMethod(req.method) && role === "viewer") {
    return { allowed: false, role, actor, reason: "viewer_read_only" };
  }

  // Operators cannot approve/move Kanban tasks to 'aprovado' or 'concluido' — admin only
  if (role === "operator" && pathname.includes("/kanban/tasks/") && pathname.endsWith("/move")) {
    return { allowed: true, role, actor, reason: "ok_operator_move_checked_by_handler" };
  }

  return { allowed: true, role, actor, reason: "ok" };
}

